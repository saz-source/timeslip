# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Autotask REST API
AUTOTASK_BASE_URL=https://webservices5.autotask.net/ATServicesRest/
AUTOTASK_USERNAME=your.email@yourcompany.com
AUTOTASK_SECRET=your_autotask_api_password
AUTOTASK_INTEGRATION_CODE=your_integration_code_here
